  "components": {
    "schemas": {
      "CreateBookingDto": {
        "required": [
          "eventId"
        ],
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "EventCreateDto": {
        "required": [
          "title",
          "description",
          "eventDate",
          "location",
          "capacity"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "description": {
            "maxLength": 1000,
            "minLength": 0,
            "type": "string"
          },
          "eventDate": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "capacity": {
            "maximum": 100000,
            "minimum": 0,
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "EventUpdateDto": {
        "required": [
          "eventDate",
          "location"
        ],
        "type": "object",
        "properties": {
          "eventDate": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          }
        }
      },
      "RegisterUserDto": {
        "required": [
          "name",
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 3,
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/RoleType"
          }
        }
      },
      "RoleType": {
        "type": "integer"
      }
    }
  },
  "tags": [
    {
      "name": "Event_Management_System"
